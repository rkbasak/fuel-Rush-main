# ─────────────────────────────────────────────────────────────────────────────
# Fuel Rush Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── Choose ONE Database Option ───────────────────────────────────────────

# Option A: Supabase Cloud (default)
# Get these from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Option B: Local PostgreSQL
# Set DATABASE_URL and comment out Supabase vars above
# DATABASE_URL=postgresql://user:password@localhost:5432/fuelrush

# ─── Choose ONE Redis Option ──────────────────────────────────────────────

# Option A: Upstash Cloud (default)
# Get these from: https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Option B: Local Redis
# Set REDIS_URL and comment out Upstash vars above
# REDIS_URL=redis://localhost:6379

# ─── Google Maps ──────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# ─── Gemini AI (primary) ───────────────────────────────────────────────────
# Get from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=your-gemini-key

# Gemini model: gemini-2.0-flash (default, fastest), gemini-1.5-flash, gemini-1.5-pro
NEXT_PUBLIC_GEMINI_MODEL=gemini-2.0-flash

# ─── OpenAI (fallback — auto-used when Gemini hits rate limit) ─────────────
# Get from: https://platform.openai.com → API Keys
OPENAI_API_KEY=

# ─── Anthropic (fallback — auto-used when Gemini/OpenAI hit rate limit) ────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ─── Groq (fast free fallback) ─────────────────────────────────────────────
# Get from: https://console.groq.com → API Keys
GROQ_API_KEY=

# ─── Firebase (optional — for push notifications) ─────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your-vapid-key

# ─── App URL ──────────────────────────────────────────────────────────────
# Your app's public URL (for OAuth callbacks, deep links)
NEXT_PUBLIC_APP_URL=https://fuelrush.app
