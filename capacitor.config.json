{
  "appId": "com.fuelrush.bd",
  "appName": "Fuel Rush",
  "webDir": "out",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0A0F1E",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "logoWidth": 120
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0A0F1E"
    },
    "Geolocation": {
      "enableHighAccuracy": true
    },
    "LocalNotifications": {
      "smallIconColor": "#F97316"
    }
  },
  "android": {
    "backgroundColor": "#0A0F1E",
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": false
  }
}
